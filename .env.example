# =====================================================================
# TRACKIT — variabili d'ambiente. Copia in `.env` e compila.
# NESSUN segreto reale va committato. `.env*` è in .gitignore (tranne questo).
# =====================================================================

# --- Database (Turso / libSQL) -------------------------------------
# In sviluppo puoi usare un file locale: file:./local.db
# In produzione: URL Turso (libsql://...) + auth token.
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# --- Better Auth ----------------------------------------------------
# Segreto per firmare sessioni/token. Genera con: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# URL base dell'app (usato per callback email, ecc.)
BETTER_AUTH_URL="http://localhost:3000"

# --- Cifratura at-rest (AES-256-GCM) --------------------------------
# Chiave a 32 byte in base64. Genera con: openssl rand -base64 32
# Usata per cifrare campi sensibili (es. token connessioni bancarie, M8).
ENCRYPTION_KEY=""

# --- Email (verifica, reset, inviti) --------------------------------
# Provider SMTP/transactional. In dev le email possono essere loggate in console.
# Da configurare a M0/M1. Esempio generico:
EMAIL_FROM="TRACKIT <no-reply@trackit.local>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# --- Allegati (Vercel Blob) -----------------------------------------
# Token per l'upload degli allegati. Se assente, l'upload è disabilitato
# (l'app funziona comunque). Su Vercel viene fornito dallo store Blob.
BLOB_READ_WRITE_TOKEN=""

# --- App ------------------------------------------------------------
# Locale di default.
NEXT_PUBLIC_DEFAULT_LOCALE="it"

# Verifica email: DISATTIVATA di default (registrazione/accesso immediati).
# Per riattivarla (richiede un SMTP configurato sopra): AUTH_REQUIRE_EMAIL_VERIFICATION="true"
# AUTH_REQUIRE_EMAIL_VERIFICATION="true"

# --- Rate limiting (produzione, opzionale) --------------------------
# In dev: in-memory (nessuna config). In prod multi-istanza: Upstash Redis.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
